pipeline {
  agent any

  options {
    timestamps()
    
    buildDiscarder(logRotator(numToKeepStr: '20'))
  }

  parameters {
    choice(name: 'DEPLOY_STRATEGY', choices: ['rolling', 'canary', 'blue-green'], description: 'Kubernetes deploy strategy')
    string(name: 'NAMESPACE', defaultValue: 'skillify', description: 'K8s namespace')
    booleanParam(name: 'RUN_TESTS', defaultValue: true, description: 'Run unit tests')
    booleanParam(name: 'PUSH_LATEST', defaultValue: true, description: 'Also push :latest tag')
    string(name: 'BRANCH', defaultValue: 'main', description: 'Branch to build')
  }

  environment {
    DOCKERHUB_CREDENTIALS = 'docker-hub-token'
    KUBECONFIG_CREDENTIALS = 'kubeconfig'
    DOCKER_USER = 'nigachu42'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout([$class: 'GitSCM', branches: [[name: "*/${params.BRANCH}" ]], userRemoteConfigs: scm.userRemoteConfigs])
        script {
          bat 'git rev-parse --short HEAD > commit.txt'
          COMMIT = readFile('commit.txt').trim()
        }
      }
    }

    stage('Install & Test') {
      parallel {
        stage('Frontend Build') {
          steps {
            dir('client') {
              bat 'npm ci'
              bat 'npm run build'
            }
          }
        }
        stage('Backend & Services Test') {
          steps {
            script {
              def backends = ['server']
              backends.each { path ->
                dir(path) {
                  bat 'npm ci'
                  if (params.RUN_TESTS) {
                    bat 'npm test'
                  } else {
                    bat 'echo Skipping tests'
                  }
                }
              }
            }
          }
        }
      }
    }

    stage('Docker Build') {
      steps {
        script {
          def images = [
            [name: 'frontend', context: 'client', dockerfile: 'services/frontend/Dockerfile'],
            [name: 'backend',  context: 'server', dockerfile: 'services/backend/Dockerfile']
          ]
          images.each { img ->
            echo "Building ${img.name} from ${img.context} using ${img.dockerfile}"
            bat "docker build -t %DOCKER_USER%/${img.name}:${COMMIT} -f ${img.dockerfile} ${img.context}"
          }
        }
      }
    }

    stage('Docker Push') {
      steps {
        withCredentials([string(credentialsId: env.DOCKERHUB_CREDENTIALS, variable: 'DOCKER_PASS_SECRET')]) {
          bat 'docker login -u %DOCKER_USER% -p %DOCKER_PASS_SECRET%'
          script {
            def services = ['frontend','backend']
            services.each { svc ->
              if (params.PUSH_LATEST) {
                bat "docker tag %DOCKER_USER%/${svc}:${COMMIT} %DOCKER_USER%/${svc}:latest"
              }
              bat "docker push %DOCKER_USER%/${svc}:${COMMIT}"
              if (params.PUSH_LATEST) {
                bat "docker push %DOCKER_USER%/${svc}:latest"
              }
            }
          }
        }
      }
    }

    stage('Deploy to Kubernetes') {
      steps {
        withCredentials([file(credentialsId: env.KUBECONFIG_CREDENTIALS, variable: 'KUBECONFIG_FILE')]) {
          script {
            def services = ['backend','frontend']
            if (params.DEPLOY_STRATEGY == 'rolling') {
              services.each { svc ->
                bat "set KUBECONFIG=%KUBECONFIG_FILE% && kubectl -n ${params.NAMESPACE} set image deployment/${svc} ${svc}=%DOCKER_USER%/${svc}:${COMMIT} --record"
              }
            } else if (params.DEPLOY_STRATEGY == 'canary') {
              echo 'Canary deploy script requires bash. Please run manually or install a Unix shell.'
            } else if (params.DEPLOY_STRATEGY == 'blue-green') {
              echo 'Blue-green deploy script requires bash. Please run manually or install a Unix shell.'
            }
          }
        }
      }
    }

    stage('Post-Deploy Health Check') {
      steps {
        echo 'Health check script requires bash. Please run manually or install a Unix shell.'
      }
    }
  }

  post {
    success {
      echo "SUCCESS: ${COMMIT}"
    }
    failure {
      echo "FAILED: see logs"
      script {
        if (params.DEPLOY_STRATEGY in ['rolling','canary']) {
          echo 'Rollback script requires bash. Please run manually or install a Unix shell.'
        }
      }
    }
  }
}
